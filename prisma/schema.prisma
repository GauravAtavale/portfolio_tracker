datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

model Stock {
  id        Int      @id @default(autoincrement())
  symbol    String   @unique
  quantity  Float
  avgCost   Float
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model WatchlistTicker {
  id        Int           @id @default(autoincrement())
  symbol    String        @unique
  note      String?
  createdAt DateTime      @default(now())
  rules     AlertRule[]
}

model AlertRule {
  id        Int             @id @default(autoincrement())
  ticker    WatchlistTicker @relation(fields: [symbol], references: [symbol])
  symbol    String
  condition String          // "drop", "spike", "volume", "52wLow", "gapDown"
  threshold Float           // e.g. 5 for 5%, 2 for 2x volume
  enabled   Boolean         @default(true)
  createdAt DateTime        @default(now())
}