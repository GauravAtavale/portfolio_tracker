datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

model Stock {
  id        Int      @id @default(autoincrement())
  symbol    String   @unique
  quantity  Float
  avgCost   Float
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model WatchlistTicker {
  id        Int           @id @default(autoincrement())
  symbol    String        @unique
  note      String?
  createdAt DateTime      @default(now())
  rules     AlertRule[]
}

model AlertRule {
  id        Int             @id @default(autoincrement())
  ticker    WatchlistTicker @relation(fields: [symbol], references: [symbol], onDelete: Cascade)
  symbol    String
  condition String
  threshold Float
  enabled   Boolean         @default(true)
  createdAt DateTime        @default(now())
}

model Simulation {
  id           Int      @id @default(autoincrement())
  symbol       String
  entryDate    DateTime
  shares       Float
  entryPrice   Float
  currentPrice Float
  gainLossPct  Float
  cagr         Float
  daysHeld     Int
  alpha        Float
  tags         String   @default("[]")
  note         String?
  createdAt    DateTime @default(now())
}